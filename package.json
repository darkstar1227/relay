{
  "name": "@dst-justin/relay",
  "version": "2.1.2",
  "description": "Multi-account switcher for Claude Code — instant credential swap across macOS, Linux, and Windows",
  "bin": {
    "relay": "./relay.js"
  },
  "files": [
    "relay",
    "relay.js",
    "relay.ps1",
    "relay.cmd",
    "postinstall.js",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node -e \"if(process.platform!=='win32'){try{require('fs').chmodSync(require('path').join(__dirname,'relay'),'755')}catch(_){}}\" && node postinstall.js"
  },
  "engines": {
    "node": ">=16"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "multi-account",
    "credential"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/darkstar1227/relay.git"
  },
  "homepage": "https://github.com/darkstar1227/relay#readme",
  "bugs": {
    "url": "https://github.com/darkstar1227/relay/issues"
  }
}
