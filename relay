#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────
# relay v2 — Claude Code 多帳號切換工具
#   !relay          選單 + 用量
#   !relay 2        按編號切換
#   !relay work     按名稱切換
# 相容 macOS bash 3.2 / Linux / WSL
# ─────────────────────────────────────────────────────────────────────
set -u

RELAY_DIR="${HOME}/.claude-relay"
CREDS_STORE="${RELAY_DIR}/credentials"
META_STORE="${RELAY_DIR}/meta"
CURRENT_FILE="${RELAY_DIR}/current"
CLAUDE_DIR="${HOME}/.claude"
CLAUDE_JSON="${HOME}/.claude.json"
REAL_CLAUDE=$(command -v claude 2>/dev/null || echo "")
# macOS: /usr/bin/python3 uses the system TLS stack (proper certs);
# /usr/local/bin/python3 (Homebrew/standalone) often lacks bundled certs → SSL failures
if [[ "$(uname)" == "Darwin" ]] && [[ -x "/usr/bin/python3" ]]; then
  PY="/usr/bin/python3"
else
  PY=$(command -v python3 || command -v python || echo "")
fi

# macOS Keychain helpers（新版 Claude Code 使用固定 service name）
# 主憑證：service="Claude Code-credentials"，account=$(whoami)
CC_KC_SVC="Claude Code-credentials"

kc_read() {
  security find-generic-password -s "${CC_KC_SVC}" -a "$(whoami)" -w 2>/dev/null
}

kc_write() {
  local content="$1" user; user=$(whoami)
  security delete-generic-password -s "${CC_KC_SVC}" -a "${user}" >/dev/null 2>&1 || true
  security add-generic-password -s "${CC_KC_SVC}" -a "${user}" -w "${content}" >/dev/null 2>&1
}

R=$'\033[0m'; B=$'\033[1m'; D=$'\033[2m'
CY=$'\033[36m'; GR=$'\033[32m'; YL=$'\033[33m'; RD=$'\033[31m'; MG=$'\033[35m'

log()  { printf "  ${CY}→${R} %s\n" "$*"; }
ok()   { printf "  ${GR}✓${R} %s\n" "$*"; }
warn() { printf "  ${YL}⚠${R} %s\n" "$*"; }
err()  { printf "  ${RD}✗${R} %s\n" "$*" >&2; }
hdr()  { printf "\n${B}${MG}  %s${R}\n  ${D}─────────────────────────────────────${R}\n" "$*"; }

mkdir -p "${CREDS_STORE}" "${META_STORE}" "${CLAUDE_DIR}"
chmod 700 "${RELAY_DIR}" "${CREDS_STORE}" 2>/dev/null || true

[[ -z "${PY}" ]] && { err "需要 python3"; exit 1; }

current_name()   { [[ -f "${CURRENT_FILE}" ]] && cat "${CURRENT_FILE}" || echo ""; }
account_creds()  { echo "${CREDS_STORE}/$1.json"; }
account_meta()   { echo "${META_STORE}/$1"; }
account_exists() { [[ -f "$(account_creds "$1")" ]]; }

# 帳號列表（排序，bash 3.2 相容：一行一個）
list_account_names() {
  local f
  for f in "${CREDS_STORE}"/*.json; do
    [[ -f "${f}" ]] || continue
    basename "${f}" .json
  done | sort
}

account_by_index() {
  local idx="$1" i=1 name
  while IFS= read -r name; do
    [[ "${i}" -eq "${idx}" ]] && { echo "${name}"; return 0; }
    i=$((i+1))
  done < <(list_account_names)
  return 1
}

# 從 ~/.claude.json 抓 email（登入後 Claude Code 會寫入 oauthAccount）
grab_email_from_claude_json() {
  [[ -f "${CLAUDE_JSON}" ]] || { echo ""; return; }
  "${PY}" - "${CLAUDE_JSON}" 2>/dev/null <<'EOF'
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    acct = d.get('oauthAccount') or {}
    print(acct.get('emailAddress') or '')
except: print('')
EOF
}

get_meta_email() {
  local f; f=$(account_meta "$1")
  [[ -f "${f}" ]] && cat "${f}" || echo "—"
}

save_meta_email() {
  local name="$1"
  local email
  email=$(grab_email_from_claude_json)
  [[ -n "${email}" ]] && echo "${email}" > "$(account_meta "${name}")"
}

require_account() {
  account_exists "$1" && return 0
  return 1
}

require_claude() {
  [[ -n "${REAL_CLAUDE}" ]] && return 0
  err "找不到 claude，請先安裝: npm i -g @anthropic-ai/claude-code"
  exit 1
}

# ══════════════════════════════════════════════════════════════════
# Python 核心：並行查 usage + 渲染表格（一次呼叫，避開 bash 3.2 限制）
# 參數: <mode: quick|full> <creds_dir> <meta_dir> <current_name> [--no-usage]
# ══════════════════════════════════════════════════════════════════
render_table() {
  "${PY}" - "$@" <<'EOF'
import sys, os, json, glob, datetime, urllib.request
from concurrent.futures import ThreadPoolExecutor, as_completed

mode, creds_dir, meta_dir, current = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
no_usage = '--no-usage' in sys.argv

R='\033[0m'; B='\033[1m'; D='\033[2m'
CY='\033[36m'; GR='\033[32m'; YL='\033[33m'; RD='\033[31m'; MG='\033[35m'

def color(u): return GR if u < 50 else (YL if u < 80 else RD)

def bar(u, w=10):
    f = round(u/100*w)
    return color(u) + '[' + '█'*f + '░'*(w-f) + ']' + R

def reset_in(iso):
    try:
        ts = datetime.datetime.fromisoformat(iso.replace('Z','+00:00'))
        s = (ts - datetime.datetime.now(datetime.timezone.utc)).total_seconds()
        if s <= 0: return '重置中'
        h, rem = divmod(int(s), 3600)
        return f'{h}h{rem//60:02d}m'
    except Exception:
        return '—'

names = sorted(os.path.basename(p)[:-5] for p in glob.glob(os.path.join(creds_dir, '*.json')))
if not names:
    print(f'  \033[33m⚠\033[0m 尚無帳號，執行: {B}relay add <名稱>{R}')
    sys.exit(0)

def get_email(name):
    p = os.path.join(meta_dir, name)
    try:
        return open(p).read().strip() or '—'
    except Exception:
        return '—'

def fetch(name):
    try:
        d = json.load(open(os.path.join(creds_dir, name + '.json')))
        tok = (d.get('claudeAiOauth') or {}).get('accessToken', '')
        if not tok:
            return name, None
        req = urllib.request.Request(
            'https://api.anthropic.com/api/oauth/usage',
            headers={'Authorization': 'Bearer ' + tok, 'User-Agent': 'relay/2.0'})
        with urllib.request.urlopen(req, timeout=6) as r:
            return name, json.loads(r.read())
    except Exception:
        return name, None

usage = {}
if not no_usage:
    sys.stderr.write('  \033[2m查詢用量...\033[0m\r')
    sys.stderr.flush()
    with ThreadPoolExecutor(max_workers=min(len(names), 6)) as ex:
        for fut in as_completed([ex.submit(fetch, n) for n in names]):
            n, d = fut.result()
            usage[n] = d
    sys.stderr.write(' ' * 30 + '\r')
    sys.stderr.flush()

def u5_str(d):
    if not d: return '—'
    fh = d.get('five_hour') or {}
    u = int(fh.get('utilization', 0) or 0)
    t = reset_in(fh.get('resets_at', ''))
    c = color(u)
    return f'{bar(u)} {c}{u:3d}%{R} {D}({t}){R}'

def u7_str(d):
    if not d: return '—'
    sd = d.get('seven_day') or {}
    u = sd.get('utilization')
    if u is None: return '—'
    u = int(u)
    c = color(u)
    f = round(u/100*8)
    return f'{c}[' + '█'*f + '░'*(8-f) + f']{R} {c}{u}%{R}'

if mode == 'quick':
    print(f'\n  {B}{MG}relay{R} {D}— 快速切換{R}')
    print(f'  {D}' + '─'*45 + R)
    for i, name in enumerate(names, 1):
        cur = name == current
        marker = f'{GR}{B}●{R}' if cur else f'{D}{i}{R}'
        ncol = GR + B if cur else B
        email = get_email(name)
        u = u5_str(usage.get(name)) if not no_usage else ''
        print(f'  {marker}  {ncol}{name:<12}{R}  {D}{email:<26}{R}  {u}')
    print()
    print(f'  {D}切換：{R}{CY}!relay <編號或名稱>{R}   {D}詳細：{R}{CY}!relay status{R}')
    print()
else:
    print(f'  {B}{"#":<3}{"帳號":<13} {"Email":<28} {"5hr 用量":<34} 週用量{R}')
    print(f'  {D}' + '─'*88 + R)
    for i, name in enumerate(names, 1):
        cur = name == current
        marker = f'{GR}●{R}' if cur else ' '
        ncol = GR + B if cur else B
        email = get_email(name)
        d = usage.get(name)
        u5 = u5_str(d) if not no_usage else '—'
        u7 = u7_str(d) if not no_usage else '—'
        # 對齊：ANSI 色碼不佔寬度，手動補
        print(f'  {marker} {D}{i:<2}{R}{ncol}{name:<12}{R} {email:<28} {u5:<52} {u7}')
    print()
    n_warn = sum(1 for d in usage.values() if d and (d.get('five_hour') or {}).get('utilization', 0) >= 80)
    if n_warn:
        print(f'  {RD}⚠ {n_warn} 個帳號用量超過 80%{R}')
EOF
}

# ══════════════════════════════════════════════════════════════════
# 核心切換
# ══════════════════════════════════════════════════════════════════
do_switch() {
  local name="$1"
  local current; current=$(current_name)

  if [[ "${current}" == "${name}" ]]; then
    ok "已經是帳號 '${B}${name}${R}'"
    return 0
  fi

  # 備份目前 credentials（讓 refresh 過的 token 不丟失）
  if [[ -n "${current}" ]] && account_exists "${current}" && [[ "$(uname)" == "Darwin" ]]; then
    local live; live=$(kc_read 2>/dev/null)
    [[ -n "${live}" ]] && printf '%s' "${live}" > "$(account_creds "${current}")"
  fi

  echo "${name}" > "${CURRENT_FILE}"

  # 寫入 macOS Keychain（新版 Claude Code 從 Keychain 讀取）
  if [[ "$(uname)" == "Darwin" ]]; then
    local content; content=$(cat "$(account_creds "${name}")")
    kc_write "${content}" || warn "Keychain 寫入失敗，切換可能無效"
  fi

  local email; email=$(get_meta_email "${name}")
  printf "\n  ${GR}${B}✓ 已切換 → %s${R}  ${D}%s${R}\n" "${name}" "${email}"
  printf "  ${D}重啟 claude 後生效。繼續舊 session：${CY}claude -c${R}\n\n"
}

# ══════════════════════════════════════════════════════════════════
# 指令
# ══════════════════════════════════════════════════════════════════

# 顯示前先把目前帳號的 token 從 Keychain 同步到檔案，避免 token 過期顯示 —
_sync_current_creds() {
  [[ "$(uname)" != "Darwin" ]] && return
  local cur; cur=$(current_name)
  [[ -z "${cur}" ]] || ! account_exists "${cur}" && return
  local live; live=$(kc_read 2>/dev/null)
  [[ -n "${live}" ]] && printf '%s' "${live}" > "$(account_creds "${cur}")"
}

cmd_quick() { _sync_current_creds; render_table quick "${CREDS_STORE}" "${META_STORE}" "$(current_name)" "$@"; }

cmd_list() {
  hdr "帳號列表"
  _sync_current_creds
  render_table full "${CREDS_STORE}" "${META_STORE}" "$(current_name)" "$@"
  echo ""
  ok "在 Claude Code 內：${CY}!relay <編號>${R} 快速切換"
}

cmd_status() {
  _sync_current_creds
  local current; current=$(current_name)
  hdr "目前狀態"
  if [[ -z "${current}" ]]; then
    warn "尚未設定帳號（使用系統預設）"
  elif ! account_exists "${current}"; then
    warn "記錄的帳號 '${current}' 已不存在"
  else
    "${PY}" - "$(account_creds "${current}")" "${current}" "$(get_meta_email "${current}")" <<'EOF'
import json, sys, datetime, urllib.request

creds_path, name, email = sys.argv[1], sys.argv[2], sys.argv[3]
R='\033[0m'; B='\033[1m'; D='\033[2m'
GR='\033[32m'; YL='\033[33m'; RD='\033[31m'; CY='\033[36m'

print(f'  {B}帳號:{R}  {GR}{B}{name}{R}')
print(f'  {B}Email:{R} {email}')

try:
    d = json.load(open(creds_path))
    tok = (d.get('claudeAiOauth') or {}).get('accessToken', '')
    if not tok:
        print(f'\n  {YL}⚠ 無 access token，請重新登入{R}'); sys.exit(0)
    req = urllib.request.Request(
        'https://api.anthropic.com/api/oauth/usage',
        headers={'Authorization': 'Bearer ' + tok, 'User-Agent': 'relay/2.0'})
    with urllib.request.urlopen(req, timeout=8) as r:
        u = json.loads(r.read())
except Exception as e:
    print(f'\n  {RD}✗ 用量查詢失敗: {e}{R}'); sys.exit(0)

def color(x): return GR if x < 50 else (YL if x < 80 else RD)
def bar(x, w=24):
    f = round(x/100*w); return '█'*f + '░'*(w-f)
def til(iso):
    try:
        ts = datetime.datetime.fromisoformat(iso.replace('Z','+00:00'))
        s = (ts - datetime.datetime.now(datetime.timezone.utc)).total_seconds()
        if s <= 0: return '即將重置'
        h, rem = divmod(int(s), 3600)
        return f'{h} 小時 {rem//60:02d} 分後重置'
    except Exception: return '—'

fh = u.get('five_hour') or {}
u5 = int(fh.get('utilization', 0) or 0)
c5 = color(u5)
print(f'\n  {B}5hr 用量:{R}')
print(f'    {c5}[{bar(u5)}]{R} {c5}{B}{u5}%{R}')
print(f'    {D}{til(fh.get("resets_at",""))}{R}')

sd = u.get('seven_day') or {}
if sd and sd.get('utilization') is not None:
    u7 = int(sd['utilization']); c7 = color(u7)
    print(f'\n  {B}週用量:{R}')
    print(f'    {c7}[{bar(u7)}]{R} {c7}{u7}%{R}')
    if sd.get('resets_at'):
        print(f'    {D}{til(sd["resets_at"])}{R}')

print()
if u5 >= 90:   print(f'  {RD}{B}⚠  即將達上限，建議：!relay <其他帳號>{R}')
elif u5 >= 70: print(f'  {YL}⚡ 用量偏高，留意切換時機{R}')
else:          print(f'  {GR}✓  用量正常{R}')
EOF
  fi
  local n=0
  [[ -d "${CLAUDE_DIR}/projects" ]] && \
    n=$(find "${CLAUDE_DIR}/projects" -name "*.jsonl" 2>/dev/null | wc -l | tr -d ' ')
  printf "\n  ${B}Sessions:${R} %s 個（所有帳號共用 ~/.claude/projects/）\n" "${n}"
}

cmd_add() {
  local name="${1:-}"
  [[ -z "${name}" ]] && { err "用法: relay add <名稱>"; exit 1; }
  case "${name}" in
    *[!a-zA-Z0-9_-]*) err "名稱只能用英數、底線、減號"; exit 1 ;;
  esac
  require_claude
  if account_exists "${name}"; then
    warn "帳號 '${name}' 已存在"
    log "強制重新登入: ${B}relay add-force ${name}${R}"
    return 0
  fi

  hdr "新增帳號: ${name}"
  warn "瀏覽器登入完成後回到終端機"
  echo ""

  # 記錄登入前的 token，用來確認是否真的做了新登入
  local tok_before; tok_before=$(kc_read 2>/dev/null | \
    "${PY}" -c "import json,sys; d=json.load(sys.stdin); print((d.get('claudeAiOauth') or {}).get('accessToken',''))" 2>/dev/null || echo "")

  "${REAL_CLAUDE}" /login || true

  local kc_creds tok_after
  kc_creds=$(kc_read 2>/dev/null)
  tok_after=$(printf '%s' "${kc_creds}" | \
    "${PY}" -c "import json,sys; d=json.load(sys.stdin); print((d.get('claudeAiOauth') or {}).get('accessToken',''))" 2>/dev/null || echo "")

  if [[ -z "${kc_creds}" ]]; then
    err "未偵測到 credentials（Keychain 內無 Claude Code 憑證）"
    log "如果已登入成功，請執行: ${B}relay save ${name}${R}"
    exit 1
  fi

  if [[ -n "${tok_before}" ]] && [[ "${tok_before}" == "${tok_after}" ]]; then
    err "登入未完成（token 未變更）"
    warn "請在 Terminal（非 Claude Code 內）執行 relay add，才能開啟瀏覽器登入"
    log "若要將目前帳號另存新名稱，請改用: ${B}relay save ${name}${R}"
    exit 1
  fi

  printf '%s' "${kc_creds}" > "$(account_creds "${name}")"
  chmod 600 "$(account_creds "${name}")"
  save_meta_email "${name}"
  echo "${name}" > "${CURRENT_FILE}"
  ok "帳號 '${B}${name}${R}' 新增成功  ${D}$(get_meta_email "${name}")${R}"
}

cmd_save() {
  local name="${1:-}"
  [[ -z "${name}" ]] && { err "用法: relay save <名稱>"; exit 1; }
  hdr "儲存目前帳號為: ${name}"

  local saved=0
  if [[ "$(uname)" == "Darwin" ]]; then
    local kc; kc=$(kc_read 2>/dev/null)
    if [[ -n "${kc}" ]]; then
      printf '%s' "${kc}" > "$(account_creds "${name}")"
      chmod 600 "$(account_creds "${name}")"
      ok "已從 Keychain 儲存"; saved=1
    fi
  fi
  [[ ${saved} -eq 0 ]] && { err "找不到 credentials，請先用 claude /login 登入"; exit 1; }

  save_meta_email "${name}"
  echo "${name}" > "${CURRENT_FILE}"
  ok "帳號 '${B}${name}${R}' 已儲存  ${D}$(get_meta_email "${name}")${R}"
}

cmd_remove() {
  local name="${1:-}"
  [[ -z "${name}" ]] && { err "用法: relay remove <名稱>"; exit 1; }
  account_exists "${name}" || { err "找不到帳號 '${name}'"; exit 1; }
  printf "\n  ${YL}確定刪除 '${B}${name}${R}${YL}'？(y/N) ${R}"
  read -r c
  [[ "${c}" = "y" || "${c}" = "Y" ]] || { log "取消"; return 0; }
  rm -f "$(account_creds "${name}")" "$(account_meta "${name}")"
  [[ "$(current_name)" == "${name}" ]] && rm -f "${CURRENT_FILE}"
  ok "已刪除 '${name}'（sessions 不受影響）"
}

cmd_sessions() {
  hdr "Sessions（全帳號共用）"
  local base="${CLAUDE_DIR}/projects"
  [[ -d "${base}" ]] || { warn "尚無 session"; return 0; }
  "${PY}" - "${base}" <<'EOF'
import os, sys, glob, datetime
base = sys.argv[1]
R='\033[0m'; B='\033[1m'; D='\033[2m'; CY='\033[36m'; GR='\033[32m'
total = 0
for proj in sorted(os.listdir(base)):
    pdir = os.path.join(base, proj)
    if not os.path.isdir(pdir): continue
    files = sorted(glob.glob(os.path.join(pdir, '*.jsonl')),
                   key=os.path.getmtime, reverse=True)
    if not files: continue
    print(f'\n  {D}{proj}{R}')
    for i, f in enumerate(files):
        sid = os.path.basename(f)[:-6]
        ts = datetime.datetime.fromtimestamp(os.path.getmtime(f)).strftime('%m/%d %H:%M')
        sz = os.path.getsize(f)
        szs = f'{sz/1048576:.1f}M' if sz > 1048576 else f'{sz//1024}K'
        mark = f'  {GR}← 最近{R}' if total == 0 and i == 0 else ''
        print(f'  {CY}{sid:<40}{R} {ts:<12} {szs}{mark}')
        total += 1
print()
print(f'  共 {total} 個 session' if total else '  尚無 session')
EOF
  log "${CY}claude -c${R} 繼續最後  ${D}|${R}  ${CY}claude -r${R} 選擇  ${D}|${R}  ${CY}claude --resume <id>${R}"
}

cmd_install() {
  local script_path; script_path="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
  local target="/usr/local/bin/relay"

  hdr "安裝 relay"

  # 嘗試建立 symlink
  if ln -sf "${script_path}" "${target}" 2>/dev/null; then
    ok "已安裝到 ${target}"
    log "執行 ${CY}relay help${R} 確認"
  elif sudo ln -sf "${script_path}" "${target}" 2>/dev/null; then
    ok "已安裝到 ${target}（sudo）"
  else
    warn "/usr/local/bin 無法寫入，改裝到 ~/bin"
    mkdir -p "${HOME}/bin"
    ln -sf "${script_path}" "${HOME}/bin/relay"
    ok "已安裝到 ${HOME}/bin/relay"
    echo ""
    warn "確認 ~/bin 在 PATH 內（.zshrc / .bashrc）："
    printf "  ${CY}echo 'export PATH=\"\$HOME/bin:\$PATH\"' >> ~/.zshrc && source ~/.zshrc${R}\n"
  fi

  echo ""
  hdr "初次設定"
  printf "  ${B}1. 新增第一個帳號${R}\n"
  printf "  ${CY}relay add personal${R}   ${D}# 開瀏覽器登入${R}\n\n"
  printf "  ${B}2.（可選）新增更多帳號${R}\n"
  printf "  ${CY}relay add work${R}\n"
  printf "  ${CY}relay add backup${R}\n\n"
  printf "  ${B}3. 在 Claude Code 裡切換${R}\n"
  printf "  ${CY}!relay${R}        ${D}# 選單 + 用量${R}\n"
  printf "  ${CY}!relay 2${R}      ${D}# 切換到第 2 個帳號${R}\n"
  printf "  ${CY}!relay work${R}   ${D}# 切換到指定名稱${R}\n\n"
}

cmd_rename() {
  local old="${1:-}" new="${2:-}"
  [[ -z "${old}" || -z "${new}" ]] && { err "用法: relay rename <舊名稱> <新名稱>"; exit 1; }
  case "${new}" in
    *[!a-zA-Z0-9_-]*) err "名稱只能用英數、底線、減號"; exit 1 ;;
  esac
  account_exists "${old}" || { err "找不到帳號 '${old}'"; exit 1; }
  account_exists "${new}" && { err "帳號 '${new}' 已存在"; exit 1; }

  mv "$(account_creds "${old}")" "$(account_creds "${new}")"
  [[ -f "$(account_meta "${old}")" ]] && mv "$(account_meta "${old}")" "$(account_meta "${new}")"
  [[ "$(current_name)" == "${old}" ]] && echo "${new}" > "${CURRENT_FILE}"
  ok "已將 '${B}${old}${R}' 重新命名為 '${B}${new}${R}'"
}

cmd_uninstall() {
  hdr "解除安裝 relay"
  warn "這將刪除 relay 指令及所有帳號憑證資料"
  printf "\n  ${YL}確定繼續？(y/N) ${R}"
  read -r c
  [[ "${c}" = "y" || "${c}" = "Y" ]] || { log "取消"; return 0; }

  local removed=0
  for p in "/usr/local/bin/relay" "${HOME}/bin/relay"; do
    if [[ -L "${p}" || -f "${p}" ]]; then
      rm -f "${p}" 2>/dev/null || sudo rm -f "${p}" 2>/dev/null || warn "無法刪除 ${p}（試試 sudo）"
      ok "已移除 ${p}"
      removed=1
    fi
  done
  [[ ${removed} -eq 0 ]] && warn "找不到已安裝的 relay 指令（手動刪除腳本本身即可）"

  if [[ -d "${RELAY_DIR}" ]]; then
    rm -rf "${RELAY_DIR}"
    ok "已刪除 ${RELAY_DIR}（所有帳號資料）"
  fi

  printf "\n  ${GR}relay 已完全移除。${R}\n\n"
}

