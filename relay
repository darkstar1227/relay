# ══════════════════════════════════════════════════════════════════
# Dispatch（單一入口，無 fall-through）
# ══════════════════════════════════════════════════════════════════
CMD="${1:-}"
[[ $# -gt 0 ]] && shift

case "${CMD}" in
  "")               cmd_quick "$@" ;;
  add)              cmd_add "$@" ;;
  add-force)
    [[ -n "${1:-}" ]] && rm -f "$(account_creds "$1")" "$(account_meta "$1")"
    cmd_add "$@" ;;
  save)             cmd_save "$@" ;;
  switch|sw|use)
    if [[ -z "${1:-}" ]]; then cmd_quick
    elif [[ "${1}" =~ ^[0-9]+$ ]]; then
      name=$(account_by_index "$1") || { err "沒有編號 $1 的帳號"; cmd_quick --no-usage; exit 1; }
      do_switch "${name}"
    else
      account_exists "$1" || { err "找不到帳號 '$1'"; cmd_quick --no-usage; exit 1; }
      do_switch "$1"
    fi ;;
  list|ls)          cmd_list "$@" ;;
  status|st)        cmd_status ;;
  remove|rm|del)    cmd_remove "$@" ;;
  rename|mv)        cmd_rename "$@" ;;
  sessions|sess)    cmd_sessions ;;
  install)          cmd_install ;;
  uninstall)        cmd_uninstall ;;
  continue|cont|c)
    if [[ -n "${1:-}" ]]; then
      account_exists "$1" && do_switch "$1"
    fi
    require_claude
    exec "${REAL_CLAUDE}" --continue ;;
  help|--help|-h)   cmd_help ;;
  *)
    # 數字 → 按編號切換；名稱 → 按名稱切換；都不是 → 錯誤
    if [[ "${CMD}" =~ ^[0-9]+$ ]]; then
      name=$(account_by_index "${CMD}") || { err "沒有編號 ${CMD} 的帳號"; cmd_quick --no-usage; exit 1; }
      do_switch "${name}"
    elif account_exists "${CMD}"; then
      do_switch "${CMD}"
    else
      err "未知指令或帳號: ${CMD}"
      cmd_quick --no-usage
      printf "  ${D}完整說明: ${CY}relay help${R}\n\n"
      exit 1
    fi ;;
esac
